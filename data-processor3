<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>数据合并处理工具 v8</title>
    <!-- SheetJS (xlsx) -->
    <script src="https://cdn.sheetjs.com/xlsx-0.20.1/package/dist/xlsx.full.min.js"></script>
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <!-- 阿里云OSS SDK -->
    <script src="https://gosspublic.alicdn.com/aliyun-oss-sdk-6.18.0.min.js"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
        }
        .container {
            max-width: 1200px;
            margin: 0 auto;
        }
        h1 {
            text-align: center;
            color: white;
            margin-bottom: 30px;
            font-size: 2rem;
        }
        .upload-sections {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }
        .upload-box {
            background: white;
            border-radius: 12px;
            padding: 25px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.2);
        }
        .upload-box h3 {
            color: #333;
            margin-bottom: 15px;
            font-size: 1.1rem;
        }
        .upload-box h3 span {
            display: inline-block;
            width: 28px;
            height: 28px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border-radius: 50%;
            text-align: center;
            line-height: 28px;
            margin-right: 10px;
            font-size: 0.9rem;
        }
        .drop-zone {
            border: 2px dashed #ccc;
            border-radius: 8px;
            padding: 40px 20px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s;
            background: #f8f9fa;
        }
        .drop-zone:hover {
            border-color: #667eea;
            background: #f0f4ff;
        }
        .drop-zone.dragover {
            border-color: #667eea;
            background: #e8eeff;
        }
        .drop-zone p {
            color: #666;
            font-size: 0.95rem;
        }
        .drop-zone .file-types {
            color: #999;
            font-size: 0.8rem;
            margin-top: 8px;
        }
        .file-list {
            margin-top: 15px;
        }
        .file-item {
            display: flex;
            align-items: center;
            padding: 10px;
            background: #f0f4ff;
            border-radius: 6px;
            margin-bottom: 8px;
        }
        .file-item .icon {
            width: 40px;
            height: 40px;
            background: #667eea;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            margin-right: 12px;
            font-size: 1.2rem;
        }
        .file-item .info {
            flex: 1;
        }
        .file-item .name {
            font-weight: 500;
            color: #333;
            font-size: 0.9rem;
        }
        .file-item .status {
            font-size: 0.8rem;
            color: #666;
        }
        .file-item .remove {
            color: #e74c3c;
            cursor: pointer;
            padding: 5px;
        }
        .process-btn {
            display: block;
            width: 100%;
            max-width: 400px;
            margin: 0 auto 30px;
            padding: 18px 40px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            border-radius: 30px;
            font-size: 1.1rem;
            font-weight: 600;
            cursor: pointer;
            transition: transform 0.2s, box-shadow 0.2s;
        }
        .process-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(102, 126, 234, 0.4);
        }
        .process-btn:disabled {
            background: #ccc;
            cursor: not-allowed;
            transform: none;
        }
        .progress {
            display: none;
            background: white;
            border-radius: 12px;
            padding: 25px;
            margin-bottom: 20px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.2);
        }
        .progress.show {
            display: block;
        }
        .progress-bar {
            height: 8px;
            background: #e0e0e0;
            border-radius: 4px;
            overflow: hidden;
            margin: 15px 0;
        }
        .progress-bar .fill {
            height: 100%;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            transition: width 0.3s;
        }
        .progress-text {
            text-align: center;
            color: #666;
        }
        .result {
            display: none;
            background: white;
            border-radius: 12px;
            padding: 25px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.2);
        }
        .result.show {
            display: block;
        }
        .result h3 {
            color: #333;
            margin-bottom: 15px;
        }
        .download-btn {
            display: inline-block;
            padding: 12px 30px;
            background: #27ae60;
            color: white;
            text-decoration: none;
            border-radius: 25px;
            font-weight: 500;
            transition: background 0.2s;
        }
        .download-btn:hover {
            background: #219a52;
        }
        .preview {
            margin-top: 20px;
            max-height: 400px;
            overflow: auto;
        }
        .preview table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.85rem;
        }
        .preview th, .preview td {
            border: 1px solid #ddd;
            padding: 8px;
            text-align: left;
        }
        .preview th {
            background: #f0f4ff;
            font-weight: 600;
        }
        .text-preview {
            margin-top: 15px;
            padding: 15px;
            background: #f8f9fa;
            border-radius: 8px;
            max-height: 200px;
            overflow: auto;
            white-space: pre-wrap;
            font-size: 0.9rem;
            color: #333;
        }
        .oss-config {
            margin-top: 20px;
            padding: 20px;
            background: #f0f4ff;
            border-radius: 8px;
            border: 1px solid #667eea;
        }
        .oss-config h4 {
            color: #333;
            margin-bottom: 15px;
            font-size: 1rem;
        }
        .oss-config .input-group {
            margin-bottom: 10px;
        }
        .oss-config label {
            display: inline-block;
            width: 120px;
            color: #666;
            font-size: 0.9rem;
        }
        .oss-config input {
            width: calc(100% - 130px);
            padding: 8px 12px;
            border: 1px solid #ddd;
            border-radius: 4px;
            font-size: 0.9rem;
        }
        .oss-config input:focus {
            outline: none;
            border-color: #667eea;
        }
        .oss-btn {
            display: inline-block;
            padding: 12px 30px;
            background: #ff6b6b;
            color: white;
            text-decoration: none;
            border-radius: 25px;
            font-weight: 500;
            transition: background 0.2s;
            margin-top: 10px;
            border: none;
            cursor: pointer;
        }
        .oss-btn:hover {
            background: #ee5a5a;
        }
        .oss-btn:disabled {
            background: #ccc;
            cursor: not-allowed;
        }
        .oss-status {
            margin-top: 10px;
            padding: 10px;
            border-radius: 4px;
            font-size: 0.9rem;
            display: none;
        }
        .oss-status.success {
            display: block;
            background: #d4edda;
            color: #155724;
        }
        .oss-status.error {
            display: block;
            background: #f8d7da;
            color: #721c24;
        }
        .oss-status.loading {
            display: block;
            background: #fff3cd;
            color: #856404;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>📊 数据合并处理工具</h1>
        
        <div class="upload-sections">
            <!-- 第一个框：文档识别 -->
            <div class="upload-box">
                <h3><span>1</span>文档文字识别</h3>
                <div class="drop-zone" id="dropZone1" onclick="document.getElementById('file1').click()">
                    <p>📄 点击或拖拽上传文件</p>
                    <p class="file-types">支持：TXT（PDF/Word/图片功能需联网）</p>
                </div>
                <input type="file" id="file1" style="display:none" accept=".txt" onchange="handleFileSelect(event, 1)">
                <div class="file-list" id="fileList1"></div>
                <div class="text-preview" id="textPreview1" style="display:none;"></div>
            </div>

            <!-- 第二个框：标定数据 -->
            <div class="upload-box">
                <h3><span>2</span>标定数据 (Excel)</h3>
                <div class="format-example" style="margin-bottom: 15px; padding: 10px; background: #f0f4ff; border-radius: 6px; border: 1px solid #667eea;">
                    <p style="color: #e74c3c; font-weight: bold; margin-bottom: 8px; font-size: 0.85rem;">⚠️ 注意！ 标定值格式：x y z</p>
                    <p style="color: #666; font-size: 0.8rem; margin-bottom: 8px;">下方写入对应的标定数据（两行三列）</p>
                    <table style="width: 100%; border-collapse: collapse; font-size: 0.8rem; background: white;">
                        <tr style="background: #d4edda;">
                            <td style="border: 1px solid #ccc; padding: 4px 8px; font-weight: bold; color: #155724;">x</td>
                            <td style="border: 1px solid #ccc; padding: 4px 8px; font-weight: bold; color: #155724;">y</td>
                            <td style="border: 1px solid #ccc; padding: 4px 8px; font-weight: bold; color: #155724;">z</td>
                        </tr>
                        <tr>
                            <td style="border: 1px solid #ccc; padding: 4px 8px;">0.00436</td>
                            <td style="border: 1px solid #ccc; padding: 4px 8px;">0.00431</td>
                            <td style="border: 1px solid #ccc; padding: 4px 8px;">0.00419</td>
                        </tr>
                    </table>
                </div>
                <div class="drop-zone" id="dropZone2" onclick="document.getElementById('file2').click()">
                    <p>📊 点击或拖拽上传 Excel</p>
                    <p class="file-types">包含 x, y, z 标定值</p>
                </div>
                <input type="file" id="file2" style="display:none" accept=".xlsx,.xls" onchange="handleFileSelect(event, 2)">
                <div class="file-list" id="fileList2"></div>
            </div>

            <!-- 第三个框：数据文件 -->
            <div class="upload-box">
                <h3><span>3</span>数据文件 (Excel)</h3>
                <div class="drop-zone" id="dropZone3" onclick="document.getElementById('file3').click()">
                    <p>📈 点击或拖拽上传 Excel</p>
                    <p class="file-types">包含时间、x1, x2, y1, y2, z 列</p>
                </div>
                <input type="file" id="file3" style="display:none" accept=".xlsx,.xls" onchange="handleFileSelect(event, 3)">
                <div class="file-list" id="fileList3"></div>
            </div>
        </div>

        <button class="process-btn" id="processBtn" onclick="processFiles()">开始处理并生成 Excel</button>

        <div class="progress" id="progress">
            <h3>⏳ 正在处理...</h3>
            <div class="progress-bar">
                <div class="fill" id="progressFill" style="width: 0%"></div>
            </div>
            <div class="progress-text" id="progressText">准备中...</div>
        </div>

        <div class="result" id="result">
            <h3>✅ 处理完成！</h3>
            <a href="#" class="download-btn" id="downloadBtn" onclick="downloadExcel()">📥 下载合并后的 Excel</a>
            
            <!-- OSS上传配置 -->
            <div class="oss-config" id="ossConfig">
                <h4>☁️ 上传到阿里云OSS（可选）</h4>
                <div class="input-group">
                    <label>Bucket名称：</label>
                    <input type="text" id="ossBucket" placeholder="your-bucket-name">
                </div>
                <div class="input-group">
                    <label>Endpoint：</label>
                    <input type="text" id="ossEndpoint" placeholder="oss-cn-hangzhou.aliyuncs.com">
                </div>
                <div class="input-group">
                    <label>AccessKey ID：</label>
                    <input type="text" id="ossAccessKeyId" placeholder="LTAI...">
                </div>
                <div class="input-group">
                    <label>AccessKey Secret：</label>
                    <input type="password" id="ossAccessKeySecret" placeholder="your-secret-key">
                </div>
                <div class="input-group">
                    <label>存储路径：</label>
                    <input type="text" id="ossPath" placeholder="data/" value="data/">
                </div>
                <button class="oss-btn" id="ossBtn" onclick="uploadToOSS()">📤 直接上传到OSS</button>
                <div class="oss-status" id="ossStatus"></div>
            </div>
            
            <div class="preview" id="preview"></div>
        </div>
    </div>

    <script>
        // 存储上传的文件和数据
        const uploadedFiles = {
            1: null,
            2: null,
            3: null
        };

        const extractedData = {
            text: '',
            parsedWorkConditions: [], // 存储解析后的工况数据
            calibration: {},
            tempVoltage: null
        };

        // 拖拽处理
        ['dropZone1', 'dropZone2', 'dropZone3'].forEach((id, index) => {
            const zone = document.getElementById(id);
            zone.addEventListener('dragover', (e) => {
                e.preventDefault();
                zone.classList.add('dragover');
            });
            zone.addEventListener('dragleave', () => {
                zone.classList.remove('dragover');
            });
            zone.addEventListener('drop', (e) => {
                e.preventDefault();
                zone.classList.remove('dragover');
                const files = e.dataTransfer.files;
                if (files.length > 0) {
                    handleFile(files[0], index + 1);
                }
            });
        });

        function handleFileSelect(event, boxNum) {
            const file = event.target.files[0];
            if (file) {
                handleFile(file, boxNum);
            }
        }

        function handleFile(file, boxNum) {
            uploadedFiles[boxNum] = file;
            
            const fileList = document.getElementById(`fileList${boxNum}`);
            const icon = getFileIcon(file.name);
            
            fileList.innerHTML = `
                <div class="file-item">
                    <div class="icon">${icon}</div>
                    <div class="info">
                        <div class="name">${file.name}</div>
                        <div class="status" id="status${boxNum}">待处理</div>
                    </div>
                    <div class="remove" onclick="removeFile(${boxNum})">✕</div>
                </div>
            `;
            
            // 如果是文本文件，立即预览
            if (boxNum === 1 && file.name.endsWith('.txt')) {
                file.text().then(text => {
                    document.getElementById('textPreview1').style.display = 'block';
                    document.getElementById('textPreview1').textContent = text.substring(0, 500) + (text.length > 500 ? '...' : '');
                });
            }
        }

        function getFileIcon(filename) {
            const ext = filename.split('.').pop().toLowerCase();
            const icons = {
                'pdf': '📄',
                'doc': '📝',
                'docx': '📝',
                'txt': '📃',
                'jpg': '🖼️',
                'jpeg': '🖼️',
                'png': '🖼️',
                'gif': '🖼️',
                'xlsx': '📊',
                'xls': '📊'
            };
            return icons[ext] || '📎';
        }

        function removeFile(boxNum) {
            uploadedFiles[boxNum] = null;
            document.getElementById(`fileList${boxNum}`).innerHTML = '';
            document.getElementById(`file${boxNum}`).value = '';
            if (boxNum === 1) {
                document.getElementById('textPreview1').style.display = 'none';
            }
        }

        async function processFiles() {
            if (!uploadedFiles[1] || !uploadedFiles[2] || !uploadedFiles[3]) {
                alert('请上传所有三个文件！');
                return;
            }

            const progress = document.getElementById('progress');
            const progressFill = document.getElementById('progressFill');
            const progressText = document.getElementById('progressText');
            const processBtn = document.getElementById('processBtn');

            progress.classList.add('show');
            processBtn.disabled = true;

            try {
                progressText.textContent = '正在读取文档文字...';
                progressFill.style.width = '25%';
                await processDocument(uploadedFiles[1]);
                document.getElementById('status1').textContent = '✓ 已读取';

                progressText.textContent = '正在读取标定数据...';
                progressFill.style.width = '50%';
                await processCalibration(uploadedFiles[2]);
                document.getElementById('status2').textContent = '✓ 已读取';

                progressText.textContent = '正在读取数据文件...';
                progressFill.style.width = '75%';
                await processDataFile(uploadedFiles[3]);
                document.getElementById('status3').textContent = '✓ 已读取';

                progressText.textContent = '正在生成合并Excel...';
                progressFill.style.width = '90%';
                await generateExcel();

                progressFill.style.width = '100%';
                progressText.textContent = '处理完成！';

                setTimeout(() => {
                    progress.classList.remove('show');
                    document.getElementById('result').classList.add('show');
                    processBtn.disabled = false;
                }, 500);

            } catch (error) {
                alert('处理出错: ' + error.message);
                console.error(error);
                processBtn.disabled = false;
            }
        }

        // 中文数字转阿拉伯数字
        function chineseToNumber(chinese) {
            const chineseNums = {
                '零': 0, '一': 1, '二': 2, '三': 3, '四': 4, '五': 5,
                '六': 6, '七': 7, '八': 8, '九': 9, '十': 10,
                '两': 2
            };
            
            if (!chinese) return null;
            
            // 处理简单的中文数字（如"八"、"九"）
            if (chinese.length === 1 && chineseNums[chinese] !== undefined) {
                return chineseNums[chinese];
            }
            
            // 处理"十X"或"X十"格式
            if (chinese.includes('十')) {
                let num = 0;
                if (chinese.startsWith('十')) {
                    num = 10 + (chineseNums[chinese[1]] || 0);
                } else if (chinese.endsWith('十')) {
                    num = chineseNums[chinese[0]] * 10;
                } else {
                    const parts = chinese.split('十');
                    num = (chineseNums[parts[0]] || 0) * 10 + (chineseNums[parts[1]] || 0);
                }
                return num;
            }
            
            // 尝试直接解析阿拉伯数字
            const arabicNum = parseInt(chinese);
            if (!isNaN(arabicNum)) {
                return arabicNum;
            }
            
            return null;
        }

        // 解析并格式化时间（支持中文时间）
        function parseAndFormatTime(timeStr) {
            if (!timeStr) return '';
            
            timeStr = timeStr.trim();
            
            // 检查是否有中文时段词（上午、下午等）
            const periodMatch = timeStr.match(/(上午|下午|早上|晚上|早晨|傍晚|凌晨)/);
            let period = periodMatch ? periodMatch[1] : '';
            
            // 检查是否有am/pm标记
            const ampmMatch = timeStr.match(/(am|pm|AM|PM)/i);
            let ampm = ampmMatch ? ampmMatch[1].toLowerCase() : '';
            
            // 提取小时和分钟
            let hour = null;
            let minute = '00';
            
            // 尝试匹配中文时间格式：九点, 九点半, 9点, 9点半 等
            const chineseTimeMatch = timeStr.match(/([\d一二三四五六七八九十两]+)\s*[点:：]\s*(\d{1,2}|半|[一二三四五六七八九十])?/);
            if (chineseTimeMatch) {
                hour = chineseToNumber(chineseTimeMatch[1]);
                const minStr = chineseTimeMatch[2];
                if (minStr === '半') {
                    minute = '30';
                } else if (minStr) {
                    const minNum = chineseToNumber(minStr);
                    minute = minNum !== null ? minNum.toString().padStart(2, '0') : minStr.padStart(2, '0');
                }
            } else {
                // 尝试匹配阿拉伯数字时间格式：9:00, 15:35, 8:32am 等
                const numTimeMatch = timeStr.match(/(\d{1,2}):(\d{2})(?::\d{2})?/);
                if (numTimeMatch) {
                    hour = parseInt(numTimeMatch[1]);
                    minute = numTimeMatch[2];
                }
            }
            
            if (hour === null) return timeStr;
            
            // 根据时段词确定am/pm
            if (!ampm && period) {
                if (period === '上午' || period === '早上' || period === '早晨' || period === '凌晨') {
                    ampm = 'am';
                } else if (period === '下午' || period === '晚上' || period === '傍晚') {
                    ampm = 'pm';
                }
            }
            
            // 格式化输出
            const formattedHour = hour.toString().padStart(2, '0');
            let result = `${formattedHour}:${minute}`;
            if (ampm) {
                result += ` ${ampm}`;
            }
            
            return result;
        }

        /**
         * 将文本中的所有中文时间转换为数字时间格式
         * 例如：凌晨三点 -> 03:00 am, 上午八点 -> 08:00 am, 下午九点半 -> 09:30 pm
         */
        function convertChineseTimeInText(text) {
            // 匹配中文时间格式：（时段词）+ 小时 + 点 + （分钟/半）+ （分）
            // 支持：凌晨三点, 上午八点, 下午九点半, 晚上午九点半 等
            const chineseTimePattern = /(凌晨|上午|下午|晚上|早上|早晨|傍晚)?\s*([\d一二三四五六七八九十两]+)\s*[点:：]\s*(\d{1,2}|半|[一二三四五六七八九十])?\s*(分)?/gi;
            
            let result = text;
            const matches = [];
            let match;
            
            // 先找出所有匹配
            while ((match = chineseTimePattern.exec(text)) !== null) {
                const period = match[1] || '';
                const hourStr = match[2];
                const minStr = match[3];
                
                let hour = chineseToNumber(hourStr);
                if (hour === null) continue;
                
                let minute = '00';
                if (minStr === '半') {
                    minute = '30';
                } else if (minStr) {
                    const minNum = chineseToNumber(minStr);
                    minute = minNum !== null ? minNum.toString().padStart(2, '0') : minStr.padStart(2, '0');
                }
                
                // 确定 am/pm
                let ampm = '';
                if (period === '上午' || period === '早上' || period === '早晨' || period === '凌晨') {
                    ampm = 'am';
                } else if (period === '下午' || period === '晚上' || period === '傍晚') {
                    ampm = 'pm';
                }
                
                // 特殊处理：如果是12小时制且没有时段词，根据小时数推断
                if (!ampm && hour <= 12) {
                    // 保持原样，不添加am/pm
                }
                
                const formattedHour = hour.toString().padStart(2, '0');
                let formattedTime = `${formattedHour}:${minute}`;
                if (ampm) {
                    formattedTime += ` ${ampm}`;
                }
                
                matches.push({
                    original: match[0],
                    formatted: formattedTime,
                    index: match.index
                });
            }
            
            // 从后往前替换，避免位置偏移
            matches.sort((a, b) => b.index - a.index);
            for (const m of matches) {
                result = result.substring(0, m.index) + m.formatted + result.substring(m.index + m.original.length);
            }
            
            return result;
        }

        /**
         * 解析工况内容
         * 格式：先识别日期，日期单独一行；时间写在日期下方，不同时间不同行；具体工况写在时间后面的第二列
         */
        function parseWorkConditions(text) {
            const lines = text.split('\n').map(line => line.trim()).filter(line => line.length > 0);
            const result = [];
            
            // 正则表达式匹配日期格式：2024-03-18 或 2024/03/18 或 2024年03月18日 等
            const datePattern = /^(\d{4}[-/年]\d{1,2}[-/月]\d{1,2}[日]?)/;
            // 正则表达式匹配时间格式：
            // 5:00, 9:00, 8:32am, 12:31 pm, 03:00 am, 09:30 pm, 凌晨三点, 上午八点 等
            const timePattern = /^(\d{1,2}:\d{2}(?::\d{2})?(?:\s*(?:am|pm|AM|PM))?)/i;
            // 中文时间模式：凌晨三点, 上午八点, 下午九点半 等
            const chineseTimePattern = /^(凌晨|上午|下午|晚上|早上|早晨|傍晚)?\s*([\d一二三四五六七八九十两]+)\s*[点:：]\s*(\d{1,2}|半|[一二三四五六七八九十])?\s*(分)?/i;
            
            let currentDate = null;
            
            for (let i = 0; i < lines.length; i++) {
                const line = lines[i];
                
                // 尝试匹配日期
                const dateMatch = line.match(datePattern);
                if (dateMatch) {
                    currentDate = dateMatch[1];
                    // 日期单独一行
                    result.push({
                        type: 'date',
                        date: currentDate,
                        time: '',
                        content: ''
                    });
                    continue;
                }
                
                // 如果当前没有日期，跳过
                if (!currentDate) continue;
                
                // 尝试匹配阿拉伯数字时间 (如 5:00, 9:00, 8:32am)
                const timeMatch = line.match(timePattern);
                if (timeMatch) {
                    const timeStr = timeMatch[1];
                    // 标准化时间格式
                    const timeParts = timeStr.match(/(\d{1,2}):(\d{2})(?::(\d{2}))?\s*(am|pm|AM|PM)?/i);
                    let formattedTime = timeStr;
                    if (timeParts) {
                        let hour = timeParts[1].padStart(2, '0');
                        let minute = timeParts[2];
                        let ampm = timeParts[4] ? timeParts[4].toLowerCase() : '';
                        formattedTime = `${hour}:${minute}`;
                        if (ampm) {
                            formattedTime += ` ${ampm}`;
                        }
                    }
                    
                    // 提取时间后面的内容作为工况
                    let content = line.substring(timeMatch[0].length).trim();
                    content = content.replace(/^[：:，,\s]+/, '').trim();
                    
                    result.push({
                        type: 'time',
                        date: currentDate,
                        time: formattedTime,
                        content: content
                    });
                    continue;
                }
                
                // 尝试匹配中文时间 (如 凌晨三点, 上午八点)
                const chineseMatch = line.match(chineseTimePattern);
                if (chineseMatch) {
                    const period = chineseMatch[1] || '';
                    const hourStr = chineseMatch[2];
                    const minStr = chineseMatch[3];
                    
                    let hour = chineseToNumber(hourStr);
                    if (hour !== null) {
                        let minute = '00';
                        if (minStr === '半') {
                            minute = '30';
                        } else if (minStr) {
                            const minNum = chineseToNumber(minStr);
                            minute = minNum !== null ? minNum.toString().padStart(2, '0') : minStr.padStart(2, '0');
                        }
                        
                        // 确定 am/pm
                        let ampm = '';
                        if (period === '上午' || period === '早上' || period === '早晨' || period === '凌晨') {
                            ampm = 'am';
                        } else if (period === '下午' || period === '晚上' || period === '傍晚') {
                            ampm = 'pm';
                        }
                        
                        let formattedTime = `${hour.toString().padStart(2, '0')}:${minute}`;
                        if (ampm) {
                            formattedTime += ` ${ampm}`;
                        }
                        
                        // 提取时间后面的内容作为工况
                        let content = line.substring(chineseMatch[0].length).trim();
                        content = content.replace(/^[：:，,\s]+/, '').trim();
                        
                        result.push({
                            type: 'time',
                            date: currentDate,
                            time: formattedTime,
                            content: content
                        });
                    }
                }
            }
            
            return result;
        }

        async function processDocument(file) {
            const ext = file.name.split('.').pop().toLowerCase();
            
            if (ext === 'txt') {
                extractedData.text = await file.text();
                // 解析工况内容
                extractedData.parsedWorkConditions = parseWorkConditions(extractedData.text);
            } else {
                extractedData.text = `[${file.name}] - 该格式需要联网支持`;
                extractedData.parsedWorkConditions = [];
            }
        }

        async function processCalibration(file) {
            const data = await readExcel(file);
            
            if (!data || data.length === 0) {
                throw new Error('标定数据文件为空');
            }
            
            const headers = Object.keys(data[0]);
            
            let xCol, yCol, zCol;
            
            for (let col of headers) {
                const colLower = String(col).toLowerCase().trim();
                if (colLower.includes('x')) {
                    xCol = col;
                } else if (colLower.includes('y')) {
                    yCol = col;
                } else if (colLower.includes('z')) {
                    zCol = col;
                }
            }

            if (!xCol && headers.length > 0) xCol = headers[0];
            if (!yCol && headers.length > 1) yCol = headers[1];
            if (!zCol && headers.length > 2) zCol = headers[2];

            const xVal = parseFloat(data[0][xCol]);
            const yVal = parseFloat(data[0][yCol]);
            const zVal = parseFloat(data[0][zCol]);
            
            if (isNaN(xVal) || isNaN(yVal) || isNaN(zVal)) {
                throw new Error(`无法读取标定值: x=${data[0][xCol]}, y=${data[0][yCol]}, z=${data[0][zCol]}`);
            }
            
            extractedData.calibration = {
                x: xVal,
                y: yVal,
                z: zVal
            };
        }

        async function processDataFile(file) {
            const rawExcelData = await readExcelRaw(file);
            
            if (!rawExcelData || rawExcelData.data.length === 0) {
                throw new Error('数据文件为空');
            }
            
            const headers = rawExcelData.data[0];
            
            let timeColIndex = 0;
            let x1ColIndex = -1, x2ColIndex = -1, y1ColIndex = -1, y2ColIndex = -1, zColIndex = -1;
            let voltageColIndex = -1;
            const tempColIndices = []; // 存储所有温度列索引
            
            for (let i = 0; i < headers.length; i++) {
                const colLower = String(headers[i]).toLowerCase().trim();
                if (colLower === 'x1') {
                    x1ColIndex = i;
                } else if (colLower === 'x2') {
                    x2ColIndex = i;
                } else if (colLower === 'y1') {
                    y1ColIndex = i;
                } else if (colLower === 'y2') {
                    y2ColIndex = i;
                } else if (colLower === 'z') {
                    zColIndex = i;
                } else if (colLower.includes('volt') || colLower.includes('电压')) {
                    voltageColIndex = i;
                } else if (colLower.includes('untitled')) {
                    // 检查该列是否为温度数据（值范围 5-40）
                    if (rawExcelData.data.length > 1) {
                        const sampleValue = parseFloat(rawExcelData.data[1][i]);
                        if (!isNaN(sampleValue) && sampleValue >= 5 && sampleValue <= 40) {
                            tempColIndices.push({
                                index: i,
                                header: headers[i]
                            });
                        } else if (!isNaN(sampleValue) && sampleValue >= 0 && sampleValue <= 1 && voltageColIndex < 0) {
                            // 电压范围 0-1
                            voltageColIndex = i;
                        }
                    }
                }
            }

            extractedData.tempVoltage = {
                headers: headers,
                timeColIndex: timeColIndex,
                x1ColIndex: x1ColIndex,
                x2ColIndex: x2ColIndex,
                y1ColIndex: y1ColIndex,
                y2ColIndex: y2ColIndex,
                zColIndex: zColIndex,
                tempColIndices: tempColIndices,  // 所有温度列
                voltageColIndex: voltageColIndex,
                rawData: rawExcelData.data
            };
        }

        async function readExcelRaw(file) {
            return new Promise((resolve, reject) => {
                const reader = new FileReader();
                reader.onload = (e) => {
                    try {
                        const data = new Uint8Array(e.target.result);
                        const workbook = XLSX.read(data, { 
                            type: 'array',
                            cellDates: false
                        });
                        
                        if (!workbook.SheetNames || workbook.SheetNames.length === 0) {
                            throw new Error('Excel文件中没有工作表');
                        }
                        
                        const firstSheetName = workbook.SheetNames[0];
                        const firstSheet = workbook.Sheets[firstSheetName];
                        
                        if (!firstSheet) {
                            throw new Error('无法读取第一个工作表');
                        }
                        
                        const jsonData = XLSX.utils.sheet_to_json(firstSheet, { 
                            header: 1,
                            raw: true
                        });
                        
                        if (!jsonData || jsonData.length === 0) {
                            throw new Error('工作表为空');
                        }
                        
                        resolve({ data: jsonData });
                    } catch (error) {
                        reject(error);
                    }
                };
                reader.onerror = reject;
                reader.readAsArrayBuffer(file);
            });
        }

        async function readExcel(file) {
            return new Promise((resolve, reject) => {
                const reader = new FileReader();
                reader.onload = (e) => {
                    try {
                        const data = new Uint8Array(e.target.result);
                        const workbook = XLSX.read(data, { type: 'array' });
                        
                        if (!workbook.SheetNames || workbook.SheetNames.length === 0) {
                            throw new Error('Excel文件中没有工作表');
                        }
                        
                        const firstSheetName = workbook.SheetNames[0];
                        const firstSheet = workbook.Sheets[firstSheetName];
                        
                        if (!firstSheet) {
                            throw new Error('无法读取第一个工作表');
                        }
                        
                        const jsonData = XLSX.utils.sheet_to_json(firstSheet, { header: 1 });
                        
                        if (!jsonData || jsonData.length === 0) {
                            throw new Error('工作表为空');
                        }
                        
                        const headers = jsonData[0];
                        const rows = [];
                        for (let i = 1; i < jsonData.length; i++) {
                            const row = {};
                            const rowData = jsonData[i];
                            for (let j = 0; j < headers.length; j++) {
                                if (headers[j] !== undefined && headers[j] !== null && headers[j] !== '') {
                                    row[headers[j]] = rowData[j];
                                }
                            }
                            if (Object.keys(row).length > 0) {
                                rows.push(row);
                            }
                        }
                        
                        resolve(rows);
                    } catch (error) {
                        reject(error);
                    }
                };
                reader.onerror = reject;
                reader.readAsArrayBuffer(file);
            });
        }

        async function generateExcel() {
            const wb = XLSX.utils.book_new();

            // 第一页：工况内容（按新格式）
            const ws1Data = [['日期/时间', '工况内容']];
            
            const parsedConditions = extractedData.parsedWorkConditions;
            if (parsedConditions.length > 0) {
                for (const item of parsedConditions) {
                    if (item.type === 'date') {
                        // 日期单独一行，第二列为空
                        ws1Data.push([item.date, '']);
                    } else if (item.type === 'time') {
                        // 时间在日期下方，工况写在第二列
                        ws1Data.push([item.time, item.content]);
                    }
                }
            } else {
                // 如果没有解析到结构化数据，显示原始文本
                ws1Data.push([extractedData.text, '']);
            }
            
            const ws1 = XLSX.utils.aoa_to_sheet(ws1Data);
            // 设置列宽
            ws1['!cols'] = [{ wch: 20 }, { wch: 50 }];
            XLSX.utils.book_append_sheet(wb, ws1, '工况内容');

            // 第二页：数据汇总
            const tvData = extractedData.tempVoltage;
            const calibration = extractedData.calibration;
            const rawData = tvData.rawData;
            
            const ws2Headers = ['时间'];
            if (tvData.x1ColIndex >= 0) ws2Headers.push('x1误差');
            if (tvData.x2ColIndex >= 0) ws2Headers.push('x2误差');
            if (tvData.y1ColIndex >= 0) ws2Headers.push('y1误差');
            if (tvData.y2ColIndex >= 0) ws2Headers.push('y2误差');
            if (tvData.zColIndex >= 0) ws2Headers.push('z误差');
            // 添加所有温度列
            if (tvData.tempColIndices && tvData.tempColIndices.length > 0) {
                for (const tempCol of tvData.tempColIndices) {
                    ws2Headers.push(tempCol.header); // 使用原始表头如 "Untitled 1"
                }
            }
            if (tvData.voltageColIndex >= 0) ws2Headers.push('电压');
            
            const ws2Data = [ws2Headers];
            
            const firstDataRow = rawData[1];
            const baseX1 = tvData.x1ColIndex >= 0 ? parseFloat(firstDataRow[tvData.x1ColIndex]) : 0;
            const baseX2 = tvData.x2ColIndex >= 0 ? parseFloat(firstDataRow[tvData.x2ColIndex]) : 0;
            const baseY1 = tvData.y1ColIndex >= 0 ? parseFloat(firstDataRow[tvData.y1ColIndex]) : 0;
            const baseY2 = tvData.y2ColIndex >= 0 ? parseFloat(firstDataRow[tvData.y2ColIndex]) : 0;
            const baseZ = tvData.zColIndex >= 0 ? parseFloat(firstDataRow[tvData.zColIndex]) : 0;
            
            for (let i = 2; i < rawData.length; i++) {
                const row = rawData[i];
                const rowData = [row[tvData.timeColIndex]];
                
                if (tvData.x1ColIndex >= 0) {
                    const val = parseFloat(row[tvData.x1ColIndex]) || 0;
                    const error = calibration.x !== 0 ? (val - baseX1) / calibration.x : 0;
                    rowData.push(error);
                }
                
                if (tvData.x2ColIndex >= 0) {
                    const val = parseFloat(row[tvData.x2ColIndex]) || 0;
                    const error = calibration.x !== 0 ? (val - baseX2) / calibration.x : 0;
                    rowData.push(error);
                }
                
                if (tvData.y1ColIndex >= 0) {
                    const val = parseFloat(row[tvData.y1ColIndex]) || 0;
                    const error = calibration.y !== 0 ? (val - baseY1) / calibration.y : 0;
                    rowData.push(error);
                }
                
                if (tvData.y2ColIndex >= 0) {
                    const val = parseFloat(row[tvData.y2ColIndex]) || 0;
                    const error = calibration.y !== 0 ? (val - baseY2) / calibration.y : 0;
                    rowData.push(error);
                }
                
                if (tvData.zColIndex >= 0) {
                    const val = parseFloat(row[tvData.zColIndex]) || 0;
                    const error = calibration.z !== 0 ? (val - baseZ) / calibration.z : 0;
                    rowData.push(error);
                }
                
                // 添加所有温度列数据
                if (tvData.tempColIndices && tvData.tempColIndices.length > 0) {
                    for (const tempCol of tvData.tempColIndices) {
                        rowData.push(row[tempCol.index]);
                    }
                }
                // 添加电压数据
                if (tvData.voltageColIndex >= 0) {
                    rowData.push(row[tvData.voltageColIndex]);
                }
                
                ws2Data.push(rowData);
            }
            
            const ws2 = XLSX.utils.aoa_to_sheet(ws2Data);
            
            // 设置第一列（时间列）的单元格格式
            const range = XLSX.utils.decode_range(ws2['!ref']);
            for (let row = range.s.r + 1; row <= range.e.r; row++) {
                const cellAddress = XLSX.utils.encode_cell({ r: row, c: 0 });
                if (ws2[cellAddress]) {
                    ws2[cellAddress].z = 'yyyy/mm/dd hh:mm:ss.000 AM/PM';
                }
            }
            
            ws2['!cols'] = [{ wch: 30 }];
            
            XLSX.utils.book_append_sheet(wb, ws2, '数据汇总');

            window.generatedWorkbook = wb;
            
            showPreview(ws2Data);
        }

        function showPreview(data) {
            const preview = document.getElementById('preview');
            let html = '<table><thead><tr>';
            data[0].forEach(header => {
                html += `<th>${header}</th>`;
            });
            html += '</tr></thead><tbody>';
            
            data.slice(1, 21).forEach(row => {
                html += '<tr>';
                row.forEach(cell => {
                    html += `<td>${cell}</td>`;
                });
                html += '</tr>';
            });
            
            if (data.length > 21) {
                html += `<tr><td colspan="${data[0].length}" style="text-align:center;color:#999;">... 还有 ${data.length - 21} 行数据 ...</td></tr>`;
            }
            
            html += '</tbody></table>';
            preview.innerHTML = html;
        }

        function downloadExcel() {
            if (window.generatedWorkbook) {
                const date = new Date().toISOString().split('T')[0];
                XLSX.writeFile(window.generatedWorkbook, `合并数据_${date}.xlsx`);
            }
        }

        // 生成Excel文件的Blob
        function generateExcelBlob() {
            if (!window.generatedWorkbook) return null;
            const wbout = XLSX.write(window.generatedWorkbook, { bookType: 'xlsx', type: 'array' });
            return new Blob([wbout], { type: 'application/octet-stream' });
        }

        // 上传到阿里云OSS
        async function uploadToOSS() {
            const bucket = document.getElementById('ossBucket').value.trim();
            const endpoint = document.getElementById('ossEndpoint').value.trim();
            const accessKeyId = document.getElementById('ossAccessKeyId').value.trim();
            const accessKeySecret = document.getElementById('ossAccessKeySecret').value.trim();
            const path = document.getElementById('ossPath').value.trim() || 'data/';
            const statusDiv = document.getElementById('ossStatus');
            const btn = document.getElementById('ossBtn');

            // 验证输入
            if (!bucket || !endpoint || !accessKeyId || !accessKeySecret) {
                statusDiv.className = 'oss-status error';
                statusDiv.textContent = '请填写完整的OSS配置信息';
                return;
            }

            const blob = generateExcelBlob();
            if (!blob) {
                statusDiv.className = 'oss-status error';
                statusDiv.textContent = '请先生成Excel文件';
                return;
            }

            btn.disabled = true;
            statusDiv.className = 'oss-status loading';
            statusDiv.textContent = '正在上传...';

            try {
                // 创建OSS客户端
                // 从 endpoint 提取 region，例如：oss-cn-shanghai.aliyuncs.com -> oss-cn-shanghai
                let region = endpoint;
                if (endpoint.includes('.aliyuncs.com')) {
                    region = endpoint.replace('.aliyuncs.com', '');
                }
                
                const client = new OSS({
                    region: region,
                    accessKeyId: accessKeyId,
                    accessKeySecret: accessKeySecret,
                    bucket: bucket,
                    secure: true  // 使用 HTTPS
                });

                // 生成文件名
                const date = new Date();
                const filename = `合并数据_${date.toISOString().split('T')[0]}_${date.getTime()}.xlsx`;
                const objectName = path + filename;

                // 上传文件
                const result = await client.put(objectName, blob);

                statusDiv.className = 'oss-status success';
                statusDiv.innerHTML = `✅ 上传成功！<br>文件地址：<a href="${result.url}" target="_blank">${result.url}</a>`;

            } catch (error) {
                console.error('OSS上传失败:', error);
                statusDiv.className = 'oss-status error';
                statusDiv.textContent = '上传失败: ' + (error.message || '请检查配置信息');
            } finally {
                btn.disabled = false;
            }
        }
    </script>
